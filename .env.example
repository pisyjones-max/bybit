# Секрет для подписи сессий Flask — сгенерируй свой:
# python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me

# Ключ шифрования API-ключей пользователей в базе — сгенерируй свой:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=change-me

# По умолчанию SQLite (файл появится в instance/novation.db).
# Для боевого использования лучше Postgres:
# DATABASE_URL=postgresql://user:password@host:5432/novation
DATABASE_URL=sqlite:///novation.db

# Порт, на котором слушает сервер
PORT=8000

# Держи =1 РОВНО на одном запущенном процессе/инстансе.
# Если процессов/воркеров больше одного — все остальные ставь RUN_ENGINE=0,
# иначе движок будет дублировать сделки для одних и тех же пользователей.
RUN_ENGINE=1

# Таймфрейм свечи, которую опрашивает движок через get_kline: 1,3,5,15,30,60,...
# (необязательно, по умолчанию 1 — минутные свечи)
# CANDLE_INTERVAL_MIN=1

# Как часто (в секундах) движок опрашивает биржу на предмет новой закрытой
# свечи. Не обязано совпадать с CANDLE_INTERVAL_MIN — это лишь частота
# проверки "не закрылся ли уже бар" (необязательно, по умолчанию 15)
# POLL_SECONDS=15

# Максимум запросов в секунду ко всем Bybit-эндпоинтам суммарно (общий
# rate-limit гейт для тикеров/свечей и ордеров всех пользователей вместе)
# (необязательно, по умолчанию 8)
# BYBIT_MAX_RPS=8
